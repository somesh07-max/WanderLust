<% layout("/layouts/boilerplate")%>
<body>

    <div class="row">
        <div class="col-8 offset-2" >
            <br> <br>
    <h1>Create New Listing :</h1>

    <form action="/Listings" method="POST" novalidate class="needs-validation">
        <div class="mb-3">
         <label for="title" class="form-label ">Title :</label>
        <input type="text" name="Listing[title]" placeholder="Add a Catchy Title " class="form-control" required>
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please Enter the Title</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description :</label>
            <textarea name="Listing[description]" id="" placeholder="Enter Description" rows="10" cols="30" class="form-control" required></textarea>
        <div class="valid-feedback">Description looks good!</div>
        <div class="invalid-feedback">Please Enter the Description</div>
        </div>

        <div class="mb-3">
            <label for="image" class="form-label">Image Link :</label>
       <input type="text" name="Listing[image]" placeholder="Enter image url" class="form-control">
        </div>

        <div class="row">
       <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price :</label>
        <input type="text" name="Listing[price]" placeholder="12,000" class="form-control" required>
        <div class="valid-feedback">Good Pricing!</div>
        <div class="invalid-feedback">Please Enter the Price</div>
        </div>
        
        <div class="mb-3 col-md-8">
        <label for="location" class="form-label">Location :</label>
         <input type="text" name="Listing[location]" placeholder="Jaipur , Rajasthan" class="form-control" required>
        <div class="valid-feedback">Nice Location!</div>
        <div class="invalid-feedback">Please Enter the Location</div>
         </div>
       
        </div>
       
         <div class="mb-3">
             <label for="country" class="form-label">Country :</label>
            <input type="text" name="Listing[country]" placeholder="India" class="form-control" required>
        <div class="valid-feedback">Great Country</div>
        <div class="invalid-feedback">Please Enter the Country</div>
         </div>
        
         <br>
         <br>

        <button class="btn btn-dark add-btn">ADD</button>
        <br>
        <br>

    </form>
    </div>
    </div>
</body>
