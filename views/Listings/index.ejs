<% layout("/layouts/boilerplate")%>
<body>
    
    <h3>All Listings</h3>

    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1">
        
        <% for(let list of allListings){%>
     <a href="/Listings/<%=list._id%>" class="listing-link">
    <div class="card col" style="width: 22rem;">
  <img src="<%=list.image%>" class="card-img-top" alt="..." style="height:20rem">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
       <b> <%=list.title%> </b> <br>
        &#8377; <%= list.price ? list.price.toLocaleString("en-IN") : "0" %>  /night
    </p>
  </div>
</div>
</a>
     <%}%>
    </div>






