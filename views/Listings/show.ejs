<div class="row justify-content-center">

    <div class="col-lg-7">

        <h1 class="text-center fw-bold mb-4">
            Listing Details
        </h1>

        <div class="card shadow border-0 rounded-4 overflow-hidden">

            <img
                src="<%= list.image %>"
                alt="<%= list.title %>"
                class="card-img-top"
                style="height: 300px; object-fit: cover;"
            >

            <div class="card-body p-4">

                <h2 class="card-title fw-bold mb-3">
                    <%= list.title %>
                </h2>

                <p class="card-text text-muted">
                    <%= list.description %>
                </p>

                <hr>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <h6 class="text-secondary">Price</h6>

                        <span class="badge bg-success fs-6 p-2">
                            ₹ <%= Number(list.price).toLocaleString("en-IN") %>
                        </span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <h6 class="text-secondary">Location</h6>

                        <p class="fw-semibold mb-0">
                            <%= list.location %>
                        </p>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-secondary">Country</h6>

                        <p class="fw-semibold mb-0">
                            <%= list.country %>
                        </p>
                    </div>

                </div>

            </div>

            <div class="card-footer bg-white border-0 p-4">

                <div class="d-flex gap-3">

                    <a
                        href="/Listings/<%= list._id %>/edit"
                        class="btn btn-warning"
                    >
                        Edit
                    </a>

                    <form
                        action="/Listings/<%= list._id %>?_method=DELETE"
                        method="POST"
                    >
                        <button
                            type="submit"
                            class="btn btn-danger"
                        >
                            Delete
                        </button>
                    </form>

                </div>

            </div>

        </div>

        <!-- Review Form -->

        <div class="card shadow-sm border-0 rounded-4 mt-5">
            <div class="card-body p-4">

                <h3 class="fw-bold mb-4">
                    ⭐ Leave a Review
                </h3>

                <form
                    action="/Listings/<%= list._id %>/reviews"
                    method="POST"
                    novalidate
                    class="needs-validation"
                >

                    <div class="mb-4">
                        <label
                            for="rating"
                            class="form-label fw-semibold form control"
                        >
                            Rating
                        </label>

                        <input
                            type="range"
                            class="form-range"
                            min="1"
                            max="5"
                            step="1"
                            id="rating"
                            name="review[rating]"
                        >

                        <div class="d-flex justify-content-between small text-muted">
                            <span>1 ★</span>
                            <span>2 ★</span>
                            <span>3 ★</span>
                            <span>4 ★</span>
                            <span>5 ★</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label
                            for="comment"
                            class="form-label fw-semibold form-control"
                        >
                            Comments
                        </label>

                       <textarea
    id="comment"
    name="review[comment]"
    class="form-control"
    rows="4"
    placeholder="Share your experience..."
    required
></textarea>

<div class="valid-feedback">
    Thanks for your review!
</div>

<div class="invalid-feedback">
    Please enter a review comment.
</div>

                    <button
                        type="submit"
                        class="btn btn-danger px-4 rounded-pill"
                    >
                        Post Review
                    </button>

                </form>

            </div>
        </div>



    </div>

         <div>
            <h4>Reviews</h4>
            <div class="row">
            <%for(let review of list.reviews){%>
                <div class="card col-6 border border-primary ms-3 mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Somesh Dewangan</h5>
                <p class="card-text">Rating : <%=review.rating%></p>
                <p class="card-text">Comment : <%=review.comment%></p>
                    </div>

                    <form action="/Listings/<%=list._id%>/reviews/<%=review._id%>?_method=DELETE" class="mb-3" method="Post">
                        <button class="btn btn-sm btn-dark">
                            Delete
                        </button>
                    </form>

                </div>

            <%}%>
            </div>
        </div>

</div>
